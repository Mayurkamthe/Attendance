<%- include('../partials/header') %>

<div class="flex flex-col lg:flex-row gap-6">

  <!-- Left panel: filter + add form -->
  <div class="w-full lg:w-72 flex-shrink-0 space-y-4">

    <!-- Filter by class -->
    <div class="card p-5">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">Select Class</h3>
      <form method="GET" action="/admin/subjects">
        <select name="classId" onchange="this.form.submit()" class="form-input">
          <option value="">— Choose a class —</option>
          <% classes.forEach(c => { %>
            <option value="<%= c._id %>" <%= selectedClass === c._id.toString() ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </form>
    </div>

    <!-- Add subject form (only when class is selected) -->
    <% if (selectedClass) { %>
    <div class="card p-5">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">Add Subject</h3>
      <form action="/admin/subjects" method="POST" class="space-y-3">
        <input type="hidden" name="classId" value="<%= selectedClass %>">
        <div>
          <label>Subject Name</label>
          <input type="text" name="name" required class="form-input" placeholder="e.g. Mathematics">
        </div>
        <div>
          <label>Subject Code <span class="text-gray-400 font-normal">(optional)</span></label>
          <input type="text" name="code" class="form-input" placeholder="e.g. MATH101">
        </div>
        <div>
          <label>Assign Teacher</label>
          <select name="teacher" required class="form-input">
            <option value="">Select Teacher</option>
            <% teachers.forEach(t => { %>
              <option value="<%= t._id %>"><%= t.name %></option>
            <% }) %>
          </select>
        </div>
        <button type="submit" class="btn-primary w-full">Add Subject</button>
      </form>
    </div>
    <% } %>
  </div>

  <!-- Right: subjects table -->
  <div class="flex-1 min-w-0">
    <div class="card overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <h3 class="text-sm font-semibold text-gray-700">
          <% if (selectedClass) { %><%= subjects.length %> Subject(s)<% } else { %>Select a class to manage subjects<% } %>
        </h3>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Subject</th>
              <th>Code</th>
              <th>Assigned Teacher</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!selectedClass) { %>
              <tr><td colspan="4" class="text-center py-12 text-gray-400">
                <svg class="w-8 h-8 mx-auto mb-2 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                Select a class from the left panel
              </td></tr>
            <% } else if (!subjects.length) { %>
              <tr><td colspan="4" class="text-center py-12 text-gray-400">No subjects added yet for this class</td></tr>
            <% } %>
            <% subjects.forEach(s => { %>
              <tr>
                <td class="font-medium text-gray-800"><%= s.name %></td>
                <td>
                  <% if (s.code) { %>
                    <span class="text-xs font-mono bg-gray-100 text-gray-600 px-2 py-0.5 rounded"><%= s.code %></span>
                  <% } else { %>
                    <span class="text-gray-400">—</span>
                  <% } %>
                </td>
                <td>
                  <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
                      <span class="text-xs font-bold text-blue-700"><%= s.teacher.name.charAt(0).toUpperCase() %></span>
                    </div>
                    <span class="text-sm text-gray-700"><%= s.teacher.name %></span>
                  </div>
                </td>
                <td>
                  <div class="flex gap-2">
                    <button onclick="openEditSubject(this)"
                      data-id="<%= s._id %>"
                      data-name="<%= encodeURIComponent(s.name) %>"
                      data-code="<%= encodeURIComponent(s.code || '') %>"
                      data-teacher="<%= s.teacher._id %>"
                      data-classid="<%= selectedClass %>"
                      class="btn-primary btn-sm">Edit</button>
                    <form action="/admin/subjects/<%= s._id %>/delete" method="POST" onsubmit="return confirm('Delete subject \'<%= s.name %>\'? Attendance records for this subject will remain.')" style="display:inline">
                      <input type="hidden" name="classId" value="<%= selectedClass %>">
                      <button type="submit" class="btn-secondary btn-sm" style="background:#fee2e2;color:#991b1b;border:none">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Summary cards per teacher (when class selected and has subjects) -->
    <% if (selectedClass && subjects.length > 0) { %>
    <div class="mt-6">
      <h3 class="text-sm font-semibold text-gray-600 mb-3">Teacher Assignment Summary</h3>
      <%
        const teacherMap = {};
        subjects.forEach(s => {
          const tid = s.teacher._id.toString();
          if (!teacherMap[tid]) teacherMap[tid] = { name: s.teacher.name, subjects: [] };
          teacherMap[tid].subjects.push(s.name);
        });
      %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% Object.values(teacherMap).forEach(t => { %>
          <div class="card p-4">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
                <span class="text-sm font-bold text-blue-700"><%= t.name.charAt(0).toUpperCase() %></span>
              </div>
              <span class="font-semibold text-gray-800 text-sm"><%= t.name %></span>
            </div>
            <div class="flex flex-wrap gap-1">
              <% t.subjects.forEach(sn => { %>
                <span class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded-full font-medium"><%= sn %></span>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

  </div>
</div>

<!-- Edit Subject Modal -->
<div id="editSubjectModal" class="modal-backdrop hidden">
  <div class="modal-box">
    <h3 class="text-base font-semibold text-gray-800 mb-4">Edit Subject</h3>
    <form id="editSubjectForm" method="POST" class="space-y-3">
      <input type="hidden" name="classId" id="esClassId">
      <div>
        <label>Subject Name</label>
        <input type="text" name="name" id="esName" required class="form-input">
      </div>
      <div>
        <label>Subject Code <span class="text-gray-400 font-normal">(optional)</span></label>
        <input type="text" name="code" id="esCode" class="form-input">
      </div>
      <div>
        <label>Assign Teacher</label>
        <select name="teacher" id="esTeacher" required class="form-input">
          <option value="">Select Teacher</option>
          <% teachers.forEach(t => { %>
            <option value="<%= t._id %>"><%= t.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="btn-primary flex-1">Save Changes</button>
        <button type="button" onclick="document.getElementById('editSubjectModal').classList.add('hidden')" class="btn-secondary flex-1">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
function openEditSubject(btn) {
  const id      = btn.dataset.id;
  const name    = decodeURIComponent(btn.dataset.name);
  const code    = decodeURIComponent(btn.dataset.code || '');
  const teacher = btn.dataset.teacher;
  const classId = btn.dataset.classid;

  document.getElementById('editSubjectForm').action = '/admin/subjects/' + id + '/update';
  document.getElementById('esName').value    = name;
  document.getElementById('esCode').value    = code;
  document.getElementById('esTeacher').value = teacher;
  document.getElementById('esClassId').value = classId;
  document.getElementById('editSubjectModal').classList.remove('hidden');
}
document.getElementById('editSubjectModal').addEventListener('click', function(e) {
  if (e.target === this) this.classList.add('hidden');
});
</script>

<%- include('../partials/footer') %>
