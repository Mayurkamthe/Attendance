<%- include('../partials/header') %>

<div class="card p-5 mb-6">
  <form method="GET" action="/admin/attendance" class="grid grid-cols-2 md:grid-cols-4 gap-4 items-end">
    <div>
      <label>Class</label>
      <select name="classId" class="form-input">
        <option value="">Select Class</option>
        <% classes.forEach(c => { %><option value="<%= c._id %>" <%= selectedClass==c._id.toString()?'selected':'' %>><%= c.name %></option><% }) %>
      </select>
    </div>
    <div>
      <label>Date</label>
      <input type="date" name="date" value="<%= selectedDate %>" class="form-input">
    </div>
    <div>
      <label>From (range)</label>
      <input type="date" name="dateFrom" value="<%= dateFrom||'' %>" class="form-input">
    </div>
    <div>
      <label>To (range)</label>
      <input type="date" name="dateTo" value="<%= dateTo||'' %>" class="form-input">
    </div>
    <div class="col-span-2 md:col-span-4">
      <button type="submit" class="btn-primary">Apply Filter</button>
    </div>
  </form>
</div>

<% if (!records.length) { %>
  <div class="card p-10 text-center text-gray-400">
    <svg class="w-10 h-10 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
    <p class="text-sm">Select a class and date to view attendance records</p>
  </div>
<% } %>

<% records.forEach(att => {
  const present = att.records.filter(r=>r.status==='present').length;
  const absent = att.records.filter(r=>r.status==='absent').length;
  const total = present+absent;
  const pct = total>0 ? Math.round(present/total*100) : 0;
%>
  <div class="card mb-5 overflow-hidden">
    <div class="px-5 py-3 bg-gray-50 border-b border-gray-100 flex flex-wrap items-center justify-between gap-3">
      <div>
        <span class="font-semibold text-gray-800 text-sm"><%= new Date(att.date).toDateString() %></span>
        <span class="text-xs text-gray-500 ml-2">By: <%= att.markedBy ? att.markedBy.name : 'Unknown' %></span>
      </div>
      <div class="flex items-center gap-3 text-xs">
        <span class="badge-present">Present: <%= present %></span>
        <span class="badge-absent">Absent: <%= absent %></span>
        <span class="bg-blue-50 text-blue-700 px-2 py-0.5 rounded-full font-semibold"><%= pct %>%</span>
      </div>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Roll No</th><th>Student</th><th>Status</th><th>WhatsApp</th><th>Override</th></tr></thead>
        <tbody>
          <% att.records.sort((a,b)=>(a.student?.rollNumber||'').localeCompare(b.student?.rollNumber||'',undefined,{numeric:true})).forEach(r => { %>
            <tr class="<%= r.status==='absent'?'bg-red-50':'' %>">
              <td class="font-mono text-gray-700"><%= r.student?r.student.rollNumber:'—' %></td>
              <td class="font-medium text-gray-800"><%= r.student?r.student.name:'Deleted Student' %></td>
              <td><span class="<%= r.status==='present'?'badge-present':'badge-absent' %>"><%= r.status.toUpperCase() %></span></td>
              <td>
                <% if (r.status==='absent' && r.student) { %>
                  <a href="https://wa.me/<%= r.student.parentPhone.replace(/\D/g,'') %>?text=Dear+Parent%2C%0AYour+child+<%= encodeURIComponent(r.student.name) %>+(Roll+No%3A+<%= r.student.rollNumber %>)+is+ABSENT+on+<%= new Date(att.date).toDateString() %>.%0A-%20<%= encodeURIComponent(collegeName) %>"
                    target="_blank" class="btn-primary btn-sm" style="background:#15803d">Send WA</a>
                <% } %>
              </td>
              <td>
                <% if (r.student) { %>
                <form action="/admin/attendance/edit" method="POST" class="flex gap-2 items-center">
                  <input type="hidden" name="attendanceId" value="<%= att._id %>">
                  <input type="hidden" name="studentId" value="<%= r.student._id %>">
                  <select name="status" class="form-input py-1 text-xs" style="width:100px;padding:5px 8px">
                    <option value="present" <%= r.status==='present'?'selected':'' %>>Present</option>
                    <option value="absent" <%= r.status==='absent'?'selected':'' %>>Absent</option>
                  </select>
                  <button type="submit" class="btn-primary btn-sm">Save</button>
                </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% }) %>

<%- include('../partials/footer') %>
