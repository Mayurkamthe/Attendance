<%- include('../partials/header') %>

<div class="flex gap-6">
  <div class="w-72 flex-shrink-0 space-y-4">
    <!-- Filter -->
    <div class="bg-white rounded-lg p-5 shadow-sm border border-slate-100">
      <h3 class="text-sm font-semibold text-slate-600 mb-3">Filter by Class</h3>
      <form method="GET" action="/admin/students">
        <select name="classId" onchange="this.form.submit()" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
          <option value="">All Classes</option>
          <% classes.forEach(c => { %><option value="<%= c._id %>" <%= selectedClass == c._id.toString() ? 'selected' : '' %>><%= c.name %></option><% }) %>
        </select>
      </form>
    </div>
    <!-- Add Student -->
    <% if (selectedClass) { %>
    <div class="bg-white rounded-lg p-5 shadow-sm border border-slate-100">
      <h3 class="text-sm font-semibold text-slate-600 mb-3">Add Student</h3>
      <form action="/admin/students" method="POST" class="space-y-3">
        <input type="hidden" name="class" value="<%= selectedClass %>">
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Full Name</label>
          <input type="text" name="name" required class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Roll Number</label>
          <input type="text" name="rollNumber" required class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Parent Phone</label>
          <input type="text" name="parentPhone" required class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
        </div>
        <button type="submit" class="w-full bg-slate-800 text-white py-2 rounded text-sm font-medium hover:bg-slate-700">Add Student</button>
      </form>
    </div>
    <!-- Bulk Upload -->
    <div class="bg-white rounded-lg p-5 shadow-sm border border-slate-100">
      <h3 class="text-sm font-semibold text-slate-600 mb-2">Bulk Upload (Excel)</h3>
      <p class="text-xs text-slate-400 mb-3">Columns: Name, Roll Number, Parent Phone</p>
      <form action="/admin/students/bulk-upload" method="POST" enctype="multipart/form-data" class="space-y-3">
        <input type="hidden" name="classId" value="<%= selectedClass %>">
        <input type="file" name="file" accept=".xlsx,.xls" required class="w-full text-xs text-slate-600 border border-slate-300 rounded px-2 py-1">
        <button type="submit" class="w-full bg-green-700 text-white py-2 rounded text-sm font-medium hover:bg-green-800">Upload</button>
      </form>
    </div>
    <% } %>
  </div>

  <div class="flex-1">
    <div class="bg-white rounded-lg shadow-sm border border-slate-100 overflow-hidden">
      <div class="px-4 py-3 border-b border-slate-100 flex justify-between items-center">
        <span class="text-sm font-medium text-slate-600"><%= students.length %> student(s)</span>
      </div>
      <table class="w-full text-sm table-hover">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-semibold text-slate-600">Roll No</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-600">Name</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-600">Parent Phone</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-600">Class</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (students.length === 0) { %>
            <tr><td colspan="5" class="text-center py-8 text-slate-400">
              <%= selectedClass ? 'No students in this class' : 'Select a class to view students' %>
            </td></tr>
          <% } %>
          <% students.forEach(s => { %>
            <tr class="border-b border-slate-100">
              <td class="px-4 py-3 font-mono text-slate-700"><%= s.rollNumber %></td>
              <td class="px-4 py-3 font-medium text-slate-700"><%= s.name %></td>
              <td class="px-4 py-3 text-slate-600"><%= s.parentPhone %></td>
              <td class="px-4 py-3 text-slate-600 text-xs"><%= s.class ? s.class.name : '-' %></td>
              <td class="px-4 py-3 flex gap-2">
                <button onclick="openEditStudent('<%= s._id %>', '<%= s.name %>', '<%= s.rollNumber %>', '<%= s.parentPhone %>')"
                  class="text-xs bg-blue-50 text-blue-700 px-2 py-1 rounded hover:bg-blue-100">Edit</button>
                <form action="/admin/students/<%= s._id %>/delete" method="POST" onsubmit="return confirm('Delete this student?')">
                  <button type="submit" class="text-xs bg-red-50 text-red-700 px-2 py-1 rounded hover:bg-red-100">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Edit Student Modal -->
<div id="editStudentModal" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">
  <div class="bg-white rounded-lg p-6 w-80 shadow-xl">
    <h3 class="text-sm font-semibold text-slate-700 mb-4">Edit Student</h3>
    <form id="editStudentForm" method="POST" class="space-y-3">
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Full Name</label>
        <input type="text" name="name" id="esName" required class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Roll Number</label>
        <input type="text" name="rollNumber" id="esRoll" required class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Parent Phone</label>
        <input type="text" name="parentPhone" id="esPhone" required class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
      </div>
      <div class="flex gap-2 pt-2">
        <button type="submit" class="flex-1 bg-slate-800 text-white py-2 rounded text-sm font-medium hover:bg-slate-700">Save</button>
        <button type="button" onclick="document.getElementById('editStudentModal').classList.add('hidden')" class="flex-1 border border-slate-300 text-slate-600 py-2 rounded text-sm hover:bg-slate-50">Cancel</button>
      </div>
    </form>
  </div>
</div>
<script>
function openEditStudent(id, name, roll, phone) {
  document.getElementById('editStudentForm').action = '/admin/students/' + id + '/update';
  document.getElementById('esName').value = name;
  document.getElementById('esRoll').value = roll;
  document.getElementById('esPhone').value = phone;
  document.getElementById('editStudentModal').classList.remove('hidden');
}
</script>
<%- include('../partials/footer') %>
