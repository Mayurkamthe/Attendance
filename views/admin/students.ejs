<%- include('../partials/header') %>

<div class="flex flex-col lg:flex-row gap-6">
  <div class="w-full lg:w-72 flex-shrink-0 space-y-4">
    <div class="card p-5">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">Filter by Class</h3>
      <form method="GET" action="/admin/students">
        <select name="classId" onchange="this.form.submit()" class="form-input">
          <option value="">All Classes</option>
          <% classes.forEach(c => { %><option value="<%= c._id %>" <%= selectedClass==c._id.toString()?'selected':'' %>><%= c.name %></option><% }) %>
        </select>
      </form>
    </div>
    <% if (selectedClass) { %>
    <div class="card p-5">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">Add Student</h3>
      <form action="/admin/students" method="POST" class="space-y-3">
        <input type="hidden" name="class" value="<%= selectedClass %>">
        <div><label>Full Name</label><input type="text" name="name" required class="form-input"></div>
        <div><label>Roll Number</label><input type="text" name="rollNumber" required class="form-input"></div>
        <div><label>Parent Phone</label><input type="text" name="parentPhone" required class="form-input" placeholder="+91..."></div>
        <button type="submit" class="btn-primary w-full">Add Student</button>
      </form>
    </div>
    <div class="card p-5">
      <h3 class="text-sm font-semibold text-gray-700 mb-1">Bulk Upload</h3>
      <p class="text-xs text-gray-400 mb-3">Excel columns: Name | Roll Number | Parent Phone</p>
      <form action="/admin/students/bulk-upload" method="POST" enctype="multipart/form-data" class="space-y-3">
        <input type="hidden" name="classId" value="<%= selectedClass %>">
        <input type="file" name="file" accept=".xlsx,.xls" required class="form-input text-xs py-2">
        <button type="submit" class="btn-primary w-full" style="background:#15803d">Upload Excel</button>
      </form>
    </div>
    <% } %>
  </div>

  <div class="flex-1 min-w-0">
    <div class="card overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <h3 class="text-sm font-semibold text-gray-700"><%= students.length %> Student(s)</h3>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Roll No</th><th>Name</th><th>Parent Phone</th><th>Class</th><th>Actions</th></tr></thead>
          <tbody>
            <% if (!students.length) { %>
              <tr><td colspan="5" class="text-center py-10 text-gray-400">
                <%= selectedClass ? 'No students in this class' : 'Select a class to view students' %>
              </td></tr>
            <% } %>
            <% students.forEach(s => { %>
              <tr>
                <td class="font-mono font-medium text-gray-800"><%= s.rollNumber %></td>
                <td class="font-medium text-gray-800"><%= s.name %></td>
                <td class="text-gray-500"><%= s.parentPhone %></td>
                <td class="text-gray-500 text-xs"><%= s.class ? s.class.name : '—' %></td>
                <td>
                  <div class="flex gap-2">
                    <button onclick="openEdit('<%= s._id %>','<%= s.name.replace(/'/g,\\'') %>','<%= s.rollNumber %>','<%= s.parentPhone %>')"
                      class="btn-primary btn-sm">Edit</button>
                    <form action="/admin/students/<%= s._id %>/delete" method="POST" onsubmit="return confirm('Delete this student?')" style="display:inline">
                      <button class="btn-secondary btn-sm" style="background:#fee2e2;color:#991b1b;border:none">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div id="editStudentModal" class="modal-backdrop hidden">
  <div class="modal-box">
    <h3 class="text-base font-semibold text-gray-800 mb-4">Edit Student</h3>
    <form id="editStudentForm" method="POST" class="space-y-3">
      <div><label>Full Name</label><input type="text" name="name" id="esName" required class="form-input"></div>
      <div><label>Roll Number</label><input type="text" name="rollNumber" id="esRoll" required class="form-input"></div>
      <div><label>Parent Phone</label><input type="text" name="parentPhone" id="esPhone" required class="form-input"></div>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="btn-primary flex-1">Save</button>
        <button type="button" onclick="document.getElementById('editStudentModal').classList.add('hidden')" class="btn-secondary flex-1">Cancel</button>
      </div>
    </form>
  </div>
</div>
<script>
function openEdit(id,name,roll,phone){
  document.getElementById('editStudentForm').action='/admin/students/'+id+'/update';
  document.getElementById('esName').value=name;
  document.getElementById('esRoll').value=roll;
  document.getElementById('esPhone').value=phone;
  document.getElementById('editStudentModal').classList.remove('hidden');
}
document.getElementById('editStudentModal').addEventListener('click',function(e){if(e.target===this)this.classList.add('hidden');});
</script>
<%- include('../partials/footer') %>
