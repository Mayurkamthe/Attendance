<%- include('../partials/header') %>

<div class="flex gap-6">
  <div class="w-72 flex-shrink-0">
    <div class="bg-white rounded-lg p-5 shadow-sm border border-slate-100">
      <h3 class="text-sm font-semibold text-slate-600 mb-4">Add Teacher</h3>
      <form action="/admin/teachers" method="POST" class="space-y-3">
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Full Name</label>
          <input type="text" name="name" required class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Email</label>
          <input type="email" name="email" required class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Phone</label>
          <input type="text" name="phone" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Password</label>
          <input type="password" name="password" required minlength="6" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Assign Classes</label>
          <select name="assignedClasses" multiple class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500 h-24">
            <% classes.forEach(c => { %><option value="<%= c._id %>"><%= c.name %></option><% }) %>
          </select>
          <p class="text-xs text-slate-400 mt-1">Hold Ctrl to select multiple</p>
        </div>
        <button type="submit" class="w-full bg-slate-800 text-white py-2 rounded text-sm font-medium hover:bg-slate-700 transition">Add Teacher</button>
      </form>
    </div>
  </div>

  <div class="flex-1">
    <div class="bg-white rounded-lg shadow-sm border border-slate-100 overflow-hidden">
      <table class="w-full text-sm table-hover">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-semibold text-slate-600">Name</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-600">Email</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-600">Phone</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-600">Classes</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-600">Status</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-600">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (teachers.length === 0) { %>
            <tr><td colspan="6" class="text-center py-8 text-slate-400">No teachers added yet</td></tr>
          <% } %>
          <% teachers.forEach(t => { %>
            <tr class="border-b border-slate-100">
              <td class="px-4 py-3 font-medium text-slate-700"><%= t.name %></td>
              <td class="px-4 py-3 text-slate-600"><%= t.email %></td>
              <td class="px-4 py-3 text-slate-600"><%= t.phone || '-' %></td>
              <td class="px-4 py-3 text-slate-600 text-xs"><%= t.assignedClasses.map(c => c.name).join(', ') || '-' %></td>
              <td class="px-4 py-3">
                <span class="text-xs px-2 py-1 rounded <%= t.isActive ? 'badge-present' : 'badge-absent' %>">
                  <%= t.isActive ? 'Active' : 'Inactive' %>
                </span>
              </td>
              <td class="px-4 py-3">
                <button onclick="openEditTeacher('<%= t._id %>', '<%= t.name %>', '<%= t.email %>', '<%= t.phone || '' %>', <%= t.isActive %>)"
                  class="text-xs bg-blue-50 text-blue-700 px-2 py-1 rounded hover:bg-blue-100">Edit</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Edit Teacher Modal -->
<div id="editTeacherModal" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">
  <div class="bg-white rounded-lg p-6 w-96 shadow-xl">
    <h3 class="text-sm font-semibold text-slate-700 mb-4">Edit Teacher</h3>
    <form id="editTeacherForm" method="POST" class="space-y-3">
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Full Name</label>
        <input type="text" name="name" id="etName" required class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Email</label>
        <input type="email" name="email" id="etEmail" required class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Phone</label>
        <input type="text" name="phone" id="etPhone" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Assign Classes</label>
        <select name="assignedClasses" multiple class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500 h-24">
          <% classes.forEach(c => { %><option value="<%= c._id %>"><%= c.name %></option><% }) %>
        </select>
      </div>
      <div class="flex items-center gap-2">
        <input type="checkbox" name="isActive" id="etActive" class="rounded">
        <label for="etActive" class="text-sm text-slate-600">Active</label>
      </div>
      <div class="flex gap-2 pt-2">
        <button type="submit" class="flex-1 bg-slate-800 text-white py-2 rounded text-sm font-medium hover:bg-slate-700">Save</button>
        <button type="button" onclick="document.getElementById('editTeacherModal').classList.add('hidden')" class="flex-1 border border-slate-300 text-slate-600 py-2 rounded text-sm hover:bg-slate-50">Cancel</button>
      </div>
    </form>
  </div>
</div>
<script>
function openEditTeacher(id, name, email, phone, isActive) {
  document.getElementById('editTeacherForm').action = '/admin/teachers/' + id + '/update';
  document.getElementById('etName').value = name;
  document.getElementById('etEmail').value = email;
  document.getElementById('etPhone').value = phone;
  document.getElementById('etActive').checked = isActive;
  document.getElementById('editTeacherModal').classList.remove('hidden');
}
</script>
<%- include('../partials/footer') %>
