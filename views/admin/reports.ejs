<%- include('../partials/header') %>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div class="card p-6">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center">
        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-800">Daily Report</h3>
        <p class="text-xs text-gray-500">Present/Absent list for a single date</p>
      </div>
    </div>
    <form action="/admin/reports/daily" method="GET" class="space-y-3">
      <div>
        <label>Class</label>
        <select name="classId" required class="form-input">
          <option value="">Select Class</option>
          <% classes.forEach(c => { %><option value="<%= c._id %>"><%= c.name %></option><% }) %>
        </select>
      </div>
      <div>
        <label>Date</label>
        <input type="date" name="date" required value="<%= new Date().toISOString().split('T')[0] %>" class="form-input">
      </div>
      <button type="submit" class="btn-primary w-full" style="background:#15803d">Download Daily Excel</button>
    </form>
  </div>

  <div class="card p-6">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center">
        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-800">Monthly Report</h3>
        <p class="text-xs text-gray-500">Full matrix with P/A per day and % attendance</p>
      </div>
    </div>
    <form action="/admin/reports/monthly" method="GET" class="space-y-3">
      <div>
        <label>Class</label>
        <select name="classId" required class="form-input">
          <option value="">Select Class</option>
          <% classes.forEach(c => { %><option value="<%= c._id %>"><%= c.name %></option><% }) %>
        </select>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label>Month</label>
          <select name="month" required class="form-input">
            <% ['January','February','March','April','May','June','July','August','September','October','November','December'].forEach((m,i) => { %>
              <option value="<%= i+1 %>" <%= new Date().getMonth()===i?'selected':'' %>><%= m %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label>Year</label>
          <input type="number" name="year" required value="<%= new Date().getFullYear() %>" min="2020" max="2099" class="form-input">
        </div>
      </div>
      <button type="submit" class="btn-primary w-full">Download Monthly Excel</button>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
