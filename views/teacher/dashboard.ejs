<%- include('../partials/header') %>

<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
  <div class="card p-5">
    <h3 class="text-sm font-semibold text-gray-700 mb-4">Your Classes</h3>
    <% if (!classes.length) { %>
      <div class="text-center py-6 text-gray-400">
        <svg class="w-8 h-8 mx-auto mb-2 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16"/></svg>
        <p class="text-sm">No classes assigned. Contact admin.</p>
      </div>
    <% } %>
    <% classes.forEach(cls => { %>
      <div class="flex items-center justify-between p-3 rounded-xl bg-gray-50 mb-2 hover:bg-blue-50 transition-all">
        <div>
          <p class="font-semibold text-gray-800 text-sm"><%= cls.name %></p>
          <p class="text-xs text-gray-500"><%= cls.year %><%= cls.department ? ' — ' + cls.department : '' %></p>
        </div>
        <a href="/teacher/attendance?classId=<%= cls._id %>" class="btn-primary btn-sm">Mark</a>
      </div>
    <% }) %>
  </div>

  <div class="space-y-4">
    <div class="card p-5">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">Quick Links</h3>
      <div class="space-y-2">
        <a href="/teacher/attendance" class="flex items-center justify-between p-3 rounded-xl bg-gray-50 hover:bg-blue-50 transition-all text-sm text-gray-700 group">
          <span>Mark Today's Attendance</span>
          <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
        <a href="/teacher/records" class="flex items-center justify-between p-3 rounded-xl bg-gray-50 hover:bg-blue-50 transition-all text-sm text-gray-700 group">
          <span>View Past Records</span>
          <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
    <div class="card p-5">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">System Info</h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between"><span class="text-gray-500">College</span><span class="font-medium text-gray-800 text-right max-w-[55%] text-xs"><%= collegeName %></span></div>
        <div class="flex justify-between"><span class="text-gray-500">Attendance Window</span><span class="font-semibold text-blue-700"><%= attStart %> – <%= attEnd %></span></div>
        <div class="flex justify-between"><span class="text-gray-500">Today</span><span class="font-medium text-gray-800"><%= new Date().toDateString() %></span></div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
