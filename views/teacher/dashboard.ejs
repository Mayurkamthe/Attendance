<%- include('../partials/header') %>

<% if (!assignedGroups.length) { %>
  <div class="card p-12 text-center">
    <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
    <p class="text-gray-500 font-medium">No subjects assigned yet</p>
    <p class="text-gray-400 text-sm mt-1">Contact the administrator to get subjects assigned to you.</p>
  </div>
<% } else { %>
  <div class="space-y-6">
    <% assignedGroups.forEach(function(group){ %>
      <div class="card overflow-hidden">
        <div class="px-5 py-3 bg-gray-50 border-b border-gray-100 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/></svg>
          </div>
          <div>
            <span class="font-semibold text-gray-800 text-sm"><%= group.cls.name %></span>
            <span class="text-xs text-gray-500 ml-2"><%= group.cls.year %><%= group.cls.department ? ' — ' + group.cls.department : '' %></span>
          </div>
        </div>
        <div class="divide-y divide-gray-50">
          <% group.subjects.forEach(function(subj){ %>
            <div class="flex items-center justify-between px-5 py-3 hover:bg-gray-50 transition-colors">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background:#eff6ff;">
                  <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-800 text-sm"><%= subj.name %></p>
                  <% if (subj.code) { %><p class="text-xs text-gray-400 font-mono"><%= subj.code %></p><% } %>
                  <p class="text-xs text-gray-400"><%= group.cls.name %></p>
                </div>
              </div>
              <div class="flex gap-2">
                <a href="/teacher/attendance?subjectId=<%= subj._id %>" class="btn-primary btn-sm">Mark</a>
                <a href="/teacher/records?subjectId=<%= subj._id %>" class="btn-secondary btn-sm">Records</a>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    <% }); %>

    <div class="card p-5">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">System Info</h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between"><span class="text-gray-500">College</span><span class="font-medium text-gray-800 text-right max-w-[55%] text-xs"><%= collegeName %></span></div>
        <div class="flex justify-between"><span class="text-gray-500">Attendance Window</span><span class="font-semibold text-blue-700"><%= attStart %> – <%= attEnd %></span></div>
        <div class="flex justify-between"><span class="text-gray-500">Today</span><span class="font-medium text-gray-800"><%= new Date().toDateString() %></span></div>
      </div>
    </div>
  </div>
<% } %>

<%- include('../partials/footer') %>
