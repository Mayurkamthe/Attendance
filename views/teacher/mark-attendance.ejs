<%- include('../partials/header') %>

<div class="flex gap-6">
  <div class="w-64 flex-shrink-0">
    <div class="bg-white rounded-lg p-5 shadow-sm border border-slate-100">
      <h3 class="text-sm font-semibold text-slate-600 mb-3">Select Class & Date</h3>
      <form method="GET" action="/teacher/attendance" class="space-y-3">
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Class</label>
          <select name="classId" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
            <option value="">Select Class</option>
            <% classes.forEach(c => { %><option value="<%= c._id %>" <%= selectedClass == c._id.toString() ? 'selected' : '' %>><%= c.name %></option><% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Date</label>
          <input type="date" name="date" value="<%= selectedDate %>" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-slate-500">
        </div>
        <button type="submit" class="w-full bg-slate-800 text-white py-2 rounded text-sm font-medium hover:bg-slate-700">Load</button>
      </form>
    </div>
  </div>

  <div class="flex-1">
    <% if (!selectedClass) { %>
      <div class="bg-white rounded-lg p-8 text-center text-slate-400 shadow-sm border border-slate-100">
        <p class="text-sm">Select a class and date to mark attendance</p>
      </div>
    <% } else if (students.length === 0) { %>
      <div class="bg-white rounded-lg p-8 text-center text-slate-400 shadow-sm border border-slate-100">
        <p class="text-sm">No students in this class</p>
      </div>
    <% } else { %>
      <% if (existing) { %>
        <div class="bg-yellow-50 border border-yellow-200 text-yellow-800 text-xs p-3 rounded mb-4">
          Attendance already marked for this date. You can update it below.
        </div>
      <% } %>
      <form action="/teacher/attendance" method="POST">
        <input type="hidden" name="classId" value="<%= selectedClass %>">
        <input type="hidden" name="date" value="<%= selectedDate %>">
        <div class="bg-white rounded-lg shadow-sm border border-slate-100 overflow-hidden">
          <div class="px-4 py-3 bg-slate-50 border-b border-slate-200 flex justify-between items-center">
            <span class="font-medium text-slate-700 text-sm"><%= students.length %> Students | <%= selectedDate %></span>
            <div class="flex gap-2">
              <button type="button" onclick="markAll('present')" class="text-xs bg-green-50 text-green-700 px-3 py-1 rounded hover:bg-green-100">All Present</button>
              <button type="button" onclick="markAll('absent')" class="text-xs bg-red-50 text-red-700 px-3 py-1 rounded hover:bg-red-100">All Absent</button>
            </div>
          </div>
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-100">
                <th class="text-left px-4 py-2 font-semibold text-slate-600">Roll No</th>
                <th class="text-left px-4 py-2 font-semibold text-slate-600">Student Name</th>
                <th class="text-left px-4 py-2 font-semibold text-slate-600">Present</th>
                <th class="text-left px-4 py-2 font-semibold text-slate-600">Absent</th>
                <% if (waEnabled) { %><th class="text-left px-4 py-2 font-semibold text-slate-600">WhatsApp</th><% } %>
              </tr>
            </thead>
            <tbody id="studentTable">
              <% students.forEach(s => {
                let existingStatus = 'present';
                if (existing) {
                  const rec = existing.records.find(r => r.student && r.student._id.toString() === s._id.toString());
                  if (rec) existingStatus = rec.status;
                }
              %>
                <tr class="border-b border-slate-100" id="row-<%= s._id %>">
                  <td class="px-4 py-2 font-mono text-slate-600"><%= s.rollNumber %></td>
                  <td class="px-4 py-2 text-slate-700"><%= s.name %></td>
                  <td class="px-4 py-2">
                    <input type="radio" name="statuses[<%= s._id %>]" value="present" <%= existingStatus === 'present' ? 'checked' : '' %>
                      class="present-radio" data-id="<%= s._id %>" onchange="updateRow('<%= s._id %>', 'present')">
                  </td>
                  <td class="px-4 py-2">
                    <input type="radio" name="statuses[<%= s._id %>]" value="absent" <%= existingStatus === 'absent' ? 'checked' : '' %>
                      class="absent-radio" data-id="<%= s._id %>" onchange="updateRow('<%= s._id %>', 'absent')">
                  </td>
                  <% if (waEnabled) { %>
                    <td class="px-4 py-2">
                      <a href="https://wa.me/<%= s.parentPhone.replace(/\D/g,'') %>?text=Dear+Parent%2C%0AYour+child+<%= encodeURIComponent(s.name) %>+(Roll+No%3A+<%= s.rollNumber %>)+is+ABSENT+on+<%= selectedDate %>.%0A-+<%= encodeURIComponent(process.env.COLLEGE_NAME) %>"
                        target="_blank" id="wa-<%= s._id %>"
                        class="text-xs bg-green-50 text-green-700 px-2 py-1 rounded hover:bg-green-100 <%= existingStatus === 'present' ? 'hidden' : '' %>">
                        Send WA
                      </a>
                    </td>
                  <% } %>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <div class="px-4 py-3 bg-slate-50 border-t border-slate-200 flex justify-end">
            <button type="submit" class="bg-slate-800 text-white px-6 py-2 rounded text-sm font-medium hover:bg-slate-700 transition">
              Save Attendance
            </button>
          </div>
        </div>
      </form>
    <% } %>
  </div>
</div>

<script>
function markAll(status) {
  document.querySelectorAll(status === 'present' ? '.present-radio' : '.absent-radio').forEach(r => {
    r.checked = true;
    updateRow(r.dataset.id, status);
  });
}
function updateRow(id, status) {
  const row = document.getElementById('row-' + id);
  if (row) {
    row.style.background = status === 'absent' ? '#fff5f5' : '';
  }
  const waLink = document.getElementById('wa-' + id);
  if (waLink) waLink.classList.toggle('hidden', status === 'present');
}
// Init row colors
document.querySelectorAll('.absent-radio:checked').forEach(r => updateRow(r.dataset.id, 'absent'));
</script>
<%- include('../partials/footer') %>
