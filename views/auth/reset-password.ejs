<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password | <%= collegeName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body class="min-h-screen flex items-center justify-center p-4" style="background:linear-gradient(135deg,#0f1f5c,#1a3080,#2340a8)">
<style>.card{background:rgba(255,255,255,0.97);border-radius:20px;box-shadow:0 25px 60px rgba(0,0,0,0.3);}</style>
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-xl font-bold text-white"><%= collegeName %></h1>
      <p class="text-blue-200 text-sm mt-1">Attendance Management System</p>
    </div>
    <div class="card p-8">
      <h2 class="text-lg font-bold text-gray-800 mb-1">Reset Password</h2>
      <p class="text-sm text-gray-500 mb-6">Enter your email and new password</p>
      <% if (error && error.length) { %>
        <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 rounded-xl p-3 mb-4 text-sm"><%= error %></div>
      <% } %>
      <% if (success && success.length) { %>
        <div class="flex items-center gap-2 bg-green-50 border border-green-200 text-green-700 rounded-xl p-3 mb-4 text-sm"><%= success %></div>
      <% } %>
      <form action="/auth/reset-password" method="POST" class="space-y-4">
        <div>
          <label>Email address</label>
          <input type="email" name="email" required class="form-input" placeholder="you@college.edu">
        </div>
        <div>
          <label>New Password</label>
          <input type="password" name="newPassword" required minlength="6" class="form-input" placeholder="Min 6 characters">
        </div>
        <button type="submit" class="btn-primary w-full">Update Password</button>
      </form>
      <div class="mt-4 text-center">
        <a href="/auth/login" class="text-xs text-blue-600 hover:text-blue-800">Back to login</a>
      </div>
    </div>
  </div>
</body>
</html>
