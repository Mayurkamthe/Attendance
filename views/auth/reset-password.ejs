<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password | <%= collegeName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    * { box-sizing: border-box; }
    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #0f1f5c 0%, #1a3080 50%, #2340a8 100%);
      display: flex; align-items: center; justify-content: center;
      padding: 1rem;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    .card {
      background: rgba(255,255,255,0.97);
      border-radius: 20px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.3);
      width: 100%; max-width: 420px;
      overflow: hidden;
    }
    .card-accent {
      height: 4px;
      background: linear-gradient(90deg, #f59e0b, #d97706, #f59e0b);
      background-size: 200% 100%;
      animation: shimmer 3s linear infinite;
    }
    @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    .step { display: flex; align-items: flex-start; gap: 14px; padding: 14px 0; border-bottom: 1px solid #f3f4f6; }
    .step:last-child { border-bottom: none; }
    .step-num {
      width: 28px; height: 28px; border-radius: 50%;
      background: linear-gradient(135deg, #1a3080, #3b5bdb);
      color: white; font-size: 12px; font-weight: 700;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="card-accent"></div>
    <div style="padding: 32px 32px 28px;">

      <!-- Header -->
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
        <div style="width:44px;height:44px;background:#fef3c7;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:22px;">🔑</div>
        <div>
          <h2 style="font-size:18px;font-weight:700;color:#111827;margin:0;">Forgot Password?</h2>
          <p style="font-size:12px;color:#9ca3af;margin:3px 0 0;"><%= collegeName %></p>
        </div>
      </div>

      <!-- Instruction box -->
      <div style="background:#fffbeb;border:1.5px solid #fde68a;border-radius:12px;padding:16px 18px;margin-bottom:20px;">
        <p style="font-size:13px;font-weight:600;color:#92400e;margin:0 0 8px;">
          Password resets are done by the system administrator.
        </p>
        <p style="font-size:12px;color:#b45309;margin:0;line-height:1.6;">
          For security, only an admin can reset your password. Please contact your administrator and they will reset it from the Teachers panel.
        </p>
      </div>

      <!-- Steps -->
      <p style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">How to reset your password</p>
      <div>
        <div class="step">
          <div class="step-num">1</div>
          <div>
            <p style="font-size:13px;font-weight:600;color:#374151;margin:0;">Contact your admin</p>
            <p style="font-size:12px;color:#9ca3af;margin:3px 0 0;">Call or message the system administrator and tell them your registered email address.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div>
            <p style="font-size:13px;font-weight:600;color:#374151;margin:0;">Admin resets your password</p>
            <p style="font-size:12px;color:#9ca3af;margin:3px 0 0;">Admin opens Teachers → clicks "Reset Password" next to your name → sets a new password.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div>
            <p style="font-size:13px;font-weight:600;color:#374151;margin:0;">Login with new password</p>
            <p style="font-size:12px;color:#9ca3af;margin:3px 0 0;">Use the new password to sign in, then change it from your profile if needed.</p>
          </div>
        </div>
      </div>

      <!-- Contact info if available -->
      <% if (collegePhone || collegeEmail) { %>
      <div style="background:#f0f9ff;border:1.5px solid #bae6fd;border-radius:12px;padding:14px 16px;margin-top:20px;">
        <p style="font-size:11px;font-weight:700;color:#0369a1;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 8px;">Admin Contact</p>
        <% if (collegePhone) { %>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
            <svg width="13" height="13" fill="none" stroke="#0284c7" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href="tel:<%= collegePhone %>" style="font-size:13px;color:#0284c7;font-weight:600;text-decoration:none;"><%= collegePhone %></a>
          </div>
        <% } %>
        <% if (collegeEmail) { %>
          <div style="display:flex;align-items:center;gap:8px;">
            <svg width="13" height="13" fill="none" stroke="#0284c7" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href="mailto:<%= collegeEmail %>" style="font-size:13px;color:#0284c7;font-weight:600;text-decoration:none;"><%= collegeEmail %></a>
          </div>
        <% } %>
      </div>
      <% } %>

      <!-- Back to login -->
      <div style="margin-top:22px;text-align:center;">
        <a href="/auth/login" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;color:#3b5bdb;font-weight:600;text-decoration:none;">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Back to Login
        </a>
      </div>

    </div>
  </div>
</body>
</html>
