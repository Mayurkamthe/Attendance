<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | <%= collegeName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/app.css">
  <script>
    tailwind.config = {
      theme: { extend: { colors: {
        primary: { 50:'#f0f4ff',100:'#e0e9ff',500:'#3b5bdb',600:'#2f4ac4',700:'#2340a8',800:'#1a3080',900:'#0f1f5c' }
      }}}
    }
  </script>
</head>
<body class="bg-gray-50 font-sans min-h-screen">

<!-- Mobile top bar (z-50, above sidebar) -->
<div class="lg:hidden fixed top-0 left-0 right-0 z-50 bg-primary-900 text-white flex items-center justify-between px-4 h-14 shadow-lg">
  <div class="flex items-center gap-3 min-w-0">
    <button onclick="toggleSidebar()" class="flex-shrink-0 p-1 rounded hover:bg-primary-700 transition">
      <svg id="menuIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
    <span class="text-sm font-semibold truncate"><%= collegeName %></span>
  </div>
  <span class="flex-shrink-0 text-xs bg-primary-700 px-2 py-1 rounded capitalize"><%= user.role %></span>
</div>

<!-- Sidebar overlay (z-35, below sidebar z-40) -->
<div id="overlay" onclick="toggleSidebar()" class="hidden fixed inset-0 bg-black bg-opacity-50 z-30 lg:hidden"></div>

<div class="flex min-h-screen">

  <!-- Sidebar (z-40 on mobile, static on desktop) -->
  <aside id="sidebar" class="fixed lg:static inset-y-0 left-0 w-64 bg-primary-900 text-white flex flex-col flex-shrink-0 -translate-x-full lg:translate-x-0 transition-transform duration-200 ease-in-out" style="z-index:40">

    <div class="hidden lg:flex items-center gap-3 px-5 py-5 border-b border-primary-700">
      <div class="w-9 h-9 rounded-xl bg-primary-700 flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
        </svg>
      </div>
      <div class="min-w-0">
        <h1 class="text-xs font-bold text-white leading-tight truncate"><%= collegeName %></h1>
        <p class="text-xs text-primary-400 mt-0.5">Attendance System</p>
      </div>
    </div>

    <!-- Mobile close header -->
    <div class="lg:hidden flex items-center justify-between px-5 py-4 border-b border-primary-700">
      <span class="text-sm font-bold text-white truncate"><%= collegeName %></span>
      <button onclick="toggleSidebar()" class="text-primary-300 hover:text-white p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <nav class="flex-1 px-3 py-4 overflow-y-auto space-y-0.5">
      <% if (user.role === 'admin') { %>
        <p class="text-xs font-semibold text-primary-500 uppercase tracking-widest px-3 mb-2 mt-1">Admin Panel</p>
        <% [
          ['/admin/dashboard','Dashboard','M3 7h18M3 12h18M3 17h18'],
          ['/admin/classes','Classes','M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1'],
          ['/admin/teachers','Teachers','M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z'],
          ['/admin/students','Students','M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z'],
          ['/admin/attendance','Attendance','M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4'],
          ['/admin/subjects','Subjects','M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'],
          ['/admin/reports','Reports','M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z']
        ].forEach(([href,label,icon]) => { %>
          <a href="<%= href %>" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-primary-200 hover:bg-primary-700 hover:text-white transition-all">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= icon %>"/></svg>
            <%= label %>
          </a>
        <% }) %>
      <% } else { %>
        <p class="text-xs font-semibold text-primary-500 uppercase tracking-widest px-3 mb-2 mt-1">Teacher Panel</p>
        <% [
          ['/teacher/dashboard','Dashboard','M3 7h18M3 12h18M3 17h18'],
          ['/teacher/attendance','Mark Attendance','M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4'],
          ['/teacher/records','View Records','M4 6h16M4 10h16M4 14h16M4 18h16']
        ].forEach(([href,label,icon]) => { %>
          <a href="<%= href %>" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-primary-200 hover:bg-primary-700 hover:text-white transition-all">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= icon %>"/></svg>
            <%= label %>
          </a>
        <% }) %>
      <% } %>
    </nav>

    <div class="px-4 py-4 border-t border-primary-700 flex-shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full bg-primary-600 flex items-center justify-center flex-shrink-0">
          <span class="text-xs font-bold text-white"><%= user.name.charAt(0).toUpperCase() %></span>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-xs font-semibold text-white truncate"><%= user.name %></p>
          <p class="text-xs text-primary-400 capitalize"><%= user.role %></p>
        </div>
        <a href="/auth/logout" title="Logout" class="flex-shrink-0 p-1.5 rounded-lg text-primary-400 hover:text-red-400 hover:bg-primary-800 transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        </a>
      </div>
    </div>
  </aside>

  <!-- Main content — pt-14 on mobile to clear fixed top bar -->
  <main class="flex-1 min-w-0 overflow-x-hidden">
    <div class="pt-14 lg:pt-0 px-4 md:px-6 lg:px-8 py-6">

      <div class="max-w-7xl mx-auto">
        <div class="mb-6">
          <h2 class="text-xl font-bold text-gray-800"><%= title %></h2>
        </div>

        <% if (typeof error !== 'undefined' && error && error.length) { %>
          <div class="flex items-start gap-3 bg-red-50 border border-red-200 text-red-700 rounded-xl p-4 mb-5 text-sm">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span><%= error %></span>
          </div>
        <% } %>
        <% if (typeof success !== 'undefined' && success && success.length) { %>
          <div class="flex items-start gap-3 bg-green-50 border border-green-200 text-green-700 rounded-xl p-4 mb-5 text-sm">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span><%= success %></span>
          </div>
        <% } %>
